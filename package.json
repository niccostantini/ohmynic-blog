{
	"name": "blog",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"postinstall": "mkdir -p static/fonts && cp node_modules/@tabler/icons-webfont/dist/fonts/tabler-icons.woff2 node_modules/@tabler/icons-webfont/dist/fonts/tabler-icons.woff node_modules/@tabler/icons-webfont/dist/fonts/tabler-icons.ttf static/fonts/ && cp node_modules/@tabler/icons-webfont/dist/tabler-icons.min.css static/fonts/tabler-icons.css && sed -i.bak 's|url(\"./fonts/|url(\"/fonts/|g' static/fonts/tabler-icons.css && rm -f static/fonts/tabler-icons.css.bak",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:migrate:safe": "bash scripts/migrate.sh",
		"db:studio": "drizzle-kit studio",
		"db:seed": "npx tsx src/lib/db/seed.ts"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/sharp": "^0.31.1",
		"@vitejs/plugin-react": "^6.0.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@blocknote/core": "^0.51.4",
		"@blocknote/mantine": "^0.51.4",
		"@blocknote/react": "^0.51.4",
		"@lucia-auth/adapter-drizzle": "^1.1.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@tabler/icons-webfont": "^3.44.0",
		"@tiptap/core": "^3.25.0",
		"@tiptap/extension-image": "^3.25.0",
		"@tiptap/extension-link": "^3.25.0",
		"@tiptap/starter-kit": "^3.25.0",
		"@types/pg": "^8.20.0",
		"@types/react": "^19.2.16",
		"@types/react-dom": "^19.2.3",
		"argon2": "^0.44.0",
		"bits-ui": "^1.0.0-next.98",
		"chart.js": "^4.5.1",
		"dotenv": "^17.4.2",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"lucia": "^3.2.2",
		"pg": "^8.21.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"resend": "^6.12.4",
		"sharp": "^0.34.5",
		"svelte-chartjs": "^4.0.1"
	}
}
